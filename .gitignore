# Build + dependencies
node_modules/
dist/
dist-test/
# Ignore docs/ contents with a single exception: docs/sample-data.json
# is a committed build artefact so the hosted "Try a sample" button
# has data to fetch. CI checkout doesn't include sample/ (ignored
# below), so the bake script skips in CI and the committed JSON is
# what ships. Re-bake + re-commit locally whenever sample/ changes.
#
# Git won't honour `!docs/sample-data.json` if `docs/` itself is
# ignored (dirs aren't descended into), so we ignore `docs/*` and
# `docs/**/` individually and then negate the one file we want.
docs/*
docs/**/
!docs/sample-data.json
# README hero + feature-tour screenshots live here so GitHub and
# the hosted Pages site can both reference them via relative paths.
# Keep each file under ~200 KB (optimise before commit).
!docs/screenshots
!docs/screenshots/*

# Local sample PBIP — raw folder is 51 MB of binaries; only the
# ~1.76 MB of text files matter and they get baked into
# docs/sample-data.json above. Raw sample stays on the author's
# machine, not in git.
sample/

# Fixture PBIP projects used by the test suite. 59 MB of real Power BI
# exports that shouldn't live in the repo — contributors run the tests
# without them and the fixture-dependent suites skip cleanly via
# `{ skip: !FIXTURE_EXISTS }` guards. Keep a local copy at test/ if
# you want to exercise the composite-model / markdown-fixture tests.
test/

# Internal-only docs — kept on disk for the maintainer but not shipped
# to GitHub. Forward-looking design notes leak direction; parked
# sponsorship copy isn't useful to readers; the roadmap is a working
# scratchpad whose visibility tends to invite feature requests for
# things that may not ship.
ROADMAP.md
claudedocs/
.github/SPONSOR-DRAFT.md

# Editor/agent state
.claude/

# Logs and OS junk
*.log
.DS_Store
Thumbs.db
